# GovCoPilot Server Configuration
PORT=3000

# Groq API Configuration (required)
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# x402 Payment Configuration
# The EVM wallet address that will receive the governance co-pilot usage payments
ASP_WALLET_ADDRESS=0x742d35Cc6634C0532925a3b844Bc454e4438f44e

# Payment cost per call (e.g. 0.05 OKB or USDC)
PAYMENT_AMOUNT=0.05

# Chain details (195 = X Layer Testnet, 196 = X Layer Mainnet)
CHAIN_ID=196
X_LAYER_RPC_URL=https://rpc.xlayer.tech

# Set to true during development/testing to skip onchain validation
BYPASS_PAYMENT_VERIFICATION=false
