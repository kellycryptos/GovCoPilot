# GovCoPilot Server Configuration
PORT=3000

# Groq API Configuration (required)
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=qwen/qwen3.6-27b

# x402 Payment Configuration
# Active network mode (mainnet or testnet)
NETWORK=mainnet

# The EVM wallet address that will receive the governance co-pilot usage payments
ASP_WALLET_ADDRESS=0xC91766bfeB093cF177936E95FF187FF7Cc13fe5b

# Payment cost per call (e.g. 0.05 USDT)
PAYMENT_AMOUNT=0.05

# Chain details (196 = X Layer Mainnet, 195 = X Layer Testnet)
CHAIN_ID=196
X_LAYER_RPC_URL=https://rpc.xlayer.tech
X_LAYER_MAINNET_RPC_URL=https://rpc.xlayer.tech
X_LAYER_TESTNET_RPC_URL=https://xlayertestrpc.okx.com

# Set to true during development/testing to skip onchain validation
BYPASS_PAYMENT_VERIFICATION=false
